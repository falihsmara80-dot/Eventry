# --- Database (Prisma / PostgreSQL) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bundleai?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/bundleai?schema=public"

# --- Server ---
PORT=5000

# --- Frontend (used for Stripe success/cancel redirect URLs) ---
FRONTEND_URL=http://localhost:5175

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- OpenAI ---
OPENAI_API_KEY="sk-replace-with-your-openai-key"
# Small model the planning agent uses (paragraph -> bundle plan -> summary)
OPENAI_AGENT_MODEL="gpt-5.4-mini-2026-03-17"

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_replace-with-your-stripe-key"
STRIPE_WEBHOOK_SECRET="whsec_replace-with-your-webhook-secret"
