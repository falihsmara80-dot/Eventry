# --- Database (Prisma / PostgreSQL) ---
# Pooled connection URL (used by Prisma at runtime)
DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require"
# Direct connection URL (used by Prisma Migrate / db push)
DIRECT_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require"

# --- Server ---
PORT=5001

# --- Frontend (used for Stripe success/cancel redirect URLs) ---
# Local: http://localhost:5175  |  Production: https://your-app.onrender.com
FRONTEND_URL=http://localhost:5175

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- OpenAI ---
OPENAI_API_KEY="sk-proj-replace-with-your-openai-key"

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_replace-with-your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_replace-with-your-webhook-secret"
